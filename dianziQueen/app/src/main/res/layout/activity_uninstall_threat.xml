<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pure_black">

    <com.dianziqueen.app.TakeoverMatrixRainView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no"
        android:layerType="software" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvUninstallThreatTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="@string/uninstall_threat_screen_title"
            android:textColor="@color/takeover_blood_red"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUninstallThreatBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:lineSpacingExtra="8dp"
            android:text="@string/uninstall_threat_screen_body"
            android:textColor="@color/text_red_primary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnUninstallSurrender"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_submit_blood"
            android:text="@string/uninstall_threat_surrender"
            android:textAllCaps="false"
            android:textColor="@color/submit_text_black"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
