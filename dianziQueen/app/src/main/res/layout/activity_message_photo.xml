<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="MergeRootFrame">
    <ImageView
        android:id="@+id/messagePhotoImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/message_photo_fullscreen_desc"
        android:scaleType="centerCrop" />

    <ProgressBar
        android:id="@+id/messagePhotoProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/messagePhotoHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC0A0000"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:padding="16dp"
        android:textColor="@color/text_red_primary"
        android:textSize="14sp" />

</FrameLayout>
