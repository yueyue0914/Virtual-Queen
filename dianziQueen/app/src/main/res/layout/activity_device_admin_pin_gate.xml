<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@drawable/bg_access_frame"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvPinGateTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_admin_pin_title"
            android:textColor="@color/crimson_glow"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPinGateMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="5dp"
            android:text="@string/device_admin_pin_message"
            android:textColor="@color/text_red_primary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etPinGate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_password_input"
            android:hint="@string/device_admin_pin_hint"
            android:importantForAutofill="no"
            android:inputType="numberPassword"
            android:padding="14dp"
            android:textColor="@color/text_red_primary"
            android:textColorHint="@color/text_red_dim"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnPinGateSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_submit_blood"
            android:text="@string/device_admin_pin_submit"
            android:textColor="@color/submit_text_black"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPinGateCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:text="@string/uninstall_guard_stay"
            android:textColor="@color/text_red_dim" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
