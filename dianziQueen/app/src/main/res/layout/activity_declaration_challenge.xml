<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="20dp"
        android:background="@drawable/bg_access_frame"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/declarationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/declaration_challenge_title"
            android:textColor="@color/crimson_glow"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDeclaration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="5dp"
            android:textColor="@color/text_red_primary"
            android:textSize="15sp" />

        <EditText
            android:id="@+id/etDeclaration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_password_input"
            android:hint="@string/declaration_challenge_input_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="@color/text_red_primary"
            android:textColorHint="@color/text_red_dim"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_submit_blood"
            android:text="@string/declaration_challenge_submit"
            android:textColor="@color/submit_text_black"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
