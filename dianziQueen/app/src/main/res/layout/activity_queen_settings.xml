<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/settingsPageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/crimson_glow"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settingsPageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_subtitle"
            android:textColor="@color/text_red_dim"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/honorific_settings_section_title"
                android:textColor="@color/text_red_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/honorific_settings_section_subtitle"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/settingsHonorificCurrentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/crimson_glow"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/settingsHonorificChangeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_submit_blood"
                android:text="@string/honorific_settings_change_btn"
                android:textAllCaps="false"
                android:textColor="@color/submit_text_black"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_injection_title"
                android:textColor="@color/text_red_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settingsGalleryCountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_red_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsCalendarCountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_red_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/settingsInjectionNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_injection_note"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/settingsFloatAvatarTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_float_avatar_title"
                android:textColor="@color/text_red_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_float_avatar_subtitle"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/settingsFloatSizeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/text_red_primary"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/settingsFloatSizeSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:max="48"
                android:progressTint="@color/crimson_glow"
                android:thumbTint="@color/crimson_glow" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/settings_float_size_hint"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/settingsFloatStyleDefault"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_queen_float_style_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/settingsFloatPreviewDefault"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@string/settings_float_avatar_default_label"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_queen_foreground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/settings_float_avatar_default_label"
                        android:textColor="@color/text_red_primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsFloatStyleNvw1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_queen_float_style_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/settingsFloatPreviewNvw1"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@string/settings_float_avatar_nvw1_label"
                        android:scaleType="centerCrop"
                        android:src="@drawable/nvw1" />

                    <TextView
                        android:id="@+id/settingsFloatStyleNvw1Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/settings_float_avatar_nvw1_label"
                        android:textColor="@color/text_red_primary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/settingsFloatStyleNvw2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_queen_float_style_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/settingsFloatPreviewNvw2"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@string/settings_float_avatar_nvw2_label"
                        android:scaleType="centerCrop"
                        android:src="@drawable/nvw2" />

                    <TextView
                        android:id="@+id/settingsFloatStyleNvw2Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/settings_float_avatar_nvw2_label"
                        android:textColor="@color/text_red_primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsFloatStyleNvw3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_queen_float_style_option"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/settingsFloatPreviewNvw3"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:contentDescription="@string/settings_float_avatar_nvw3_label"
                        android:scaleType="centerCrop"
                        android:src="@drawable/nvw3" />

                    <TextView
                        android:id="@+id/settingsFloatStyleNvw3Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/settings_float_avatar_nvw3_label"
                        android:textColor="@color/text_red_primary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/perm_check_title"
                android:textColor="@color/text_red_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/perm_check_subtitle"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />

            <Button
                android:id="@+id/settingsPermCheckButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_submit_blood"
                android:text="@string/settings_perm_check_btn"
                android:textAllCaps="false"
                android:textColor="@color/submit_text_black"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_declaration_title"
                android:textColor="@color/crimson_glow"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_declaration_subtitle"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/settingsDeclarationEnabledSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_declaration_enabled"
                android:textColor="@color/text_red_primary" />

            <RadioGroup
                android:id="@+id/settingsDeclarationModeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/settingsDeclarationModeRandom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_declaration_mode_random"
                    android:textColor="@color/text_red_primary" />

                <RadioButton
                    android:id="@+id/settingsDeclarationModeFixed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/settings_declaration_mode_fixed"
                    android:textColor="@color/text_red_primary" />
            </RadioGroup>

            <TextView
                android:id="@+id/settingsDeclarationRandomMinLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:labelFor="@id/settingsDeclarationRandomMinEdit"
                android:text="@string/settings_declaration_random_min_label"
                android:textColor="@color/text_red_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/settingsDeclarationRandomMinEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_password_input"
                android:importantForAutofill="no"
                android:inputType="number"
                android:padding="10dp"
                android:textColor="@color/text_red_primary" />

            <TextView
                android:id="@+id/settingsDeclarationRandomMaxLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:labelFor="@id/settingsDeclarationRandomMaxEdit"
                android:text="@string/settings_declaration_random_max_label"
                android:textColor="@color/text_red_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/settingsDeclarationRandomMaxEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_password_input"
                android:importantForAutofill="no"
                android:inputType="number"
                android:padding="10dp"
                android:textColor="@color/text_red_primary" />

            <TextView
                android:id="@+id/settingsDeclarationFixedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:labelFor="@id/settingsDeclarationFixedEdit"
                android:text="@string/settings_declaration_fixed_label"
                android:textColor="@color/text_red_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/settingsDeclarationFixedEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_password_input"
                android:importantForAutofill="no"
                android:inputType="number"
                android:padding="10dp"
                android:textColor="@color/text_red_primary" />

            <TextView
                android:id="@+id/settingsDeclarationPreviewText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_red_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsDeclarationSaveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_submit_blood"
                android:text="@string/settings_declaration_save_btn"
                android:textAllCaps="false"
                android:textColor="@color/submit_text_black"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_strong_control_title"
                android:textColor="@color/crimson_glow"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_strong_control_subtitle"
                android:textColor="@color/text_red_dim"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/settingsStrongControlStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/text_red_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsStrongControlDisableButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_submit_blood"
                android:text="@string/settings_strong_control_disable_btn"
                android:textAllCaps="false"
                android:textColor="@color/submit_text_black"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_release_title"
                android:textColor="@color/crimson_glow"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/settingsReleaseBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_red_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/settingsReleaseButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_submit_blood"
                android:textColor="@color/submit_text_black"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
