<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="22dp"
    android:paddingTop="28dp"
    android:paddingEnd="22dp"
    android:paddingBottom="16dp"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/profileTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/profilePointsText"
                android:layout_marginEnd="8dp"
                android:letterSpacing="0.12"
                android:text="@string/profile_title"
                android:textColor="@color/crimson_glow"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profilePointsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textColor="@color/text_red_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/profileSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/profile_subtitle"
            android:textColor="@color/text_red_dim"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_access_frame"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/profileSlaveLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/text_red_dim"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/profileSlaveValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_red_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileDeviceNameLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="monospace"
                android:textColor="@color/text_red_dim"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/profileDeviceNameValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/text_red_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/profileModelLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="monospace"
                android:textColor="@color/text_red_dim"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/profileModelValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_red_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/profileStatusLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="monospace"
                android:textColor="@color/text_red_dim"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/profileStatusValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/crimson_glow"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileRenameLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="monospace"
                android:textColor="@color/text_red_dim"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/profileRenameValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_red_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/profileOverlayCheckButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:padding="14dp"
            android:text="@string/profile_overlay_check"
            android:textColor="@color/text_red_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/profileSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_access_frame"
            android:padding="14dp"
            android:text="@string/profile_open_settings"
            android:textColor="@color/text_red_primary"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
