<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/permCheckTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/perm_check_title"
            android:textColor="@color/crimson_glow"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/permCheckSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/perm_check_subtitle"
            android:textColor="@color/text_red_dim"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_access_frame"
            android:padding="14dp"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/permissionListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnCheckAgain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_access_frame"
            android:text="@string/perm_check_btn_refresh"
            android:textAllCaps="false"
            android:textColor="@color/text_red_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenAutoStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_access_frame"
            android:text="@string/perm_check_btn_autostart"
            android:textAllCaps="false"
            android:textColor="@color/text_red_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_access_frame"
            android:text="@string/perm_check_btn_overlay"
            android:textAllCaps="false"
            android:textColor="@color/text_red_primary"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_submit_blood"
            android:text="@string/perm_check_btn_rom_guide"
            android:textAllCaps="false"
            android:textColor="@color/submit_text_black"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
